#!/usr/bin/python3
# -*- coding: utf-8 -*-

import sys
from re import search, sub
from datetime import date
from os.path import dirname, join, splitext
from os import chdir
import gpxpy

def print_leaflet_gpx_routes_js():
    target_dir = dirname(sys.argv[1])
    if target_dir:
        chdir(target_dir)

    g_js = ''
    for d in map_data.values():
        for r in d['routes']:
            with open(r.strip(), 'r') as f:
                g_js += '`' + f.read() + '`,\n'
    print(g_js.rstrip(',\n'))

def print_leaflet_markers_js():
    m_js = ''
    for d in map_data.values():
        for m in d['markers']:
            clean_txt = m['txt'].replace("'", "\\'")
            m_js += "{ lat: " + m['lat'] + ", lng: " + m['lng'] + ", label: '" + clean_txt + "' },\n"
    print(m_js.rstrip(',\n'))

def ordinal(n):
    if 10 <= n % 100 <= 20:
        suffix = 'th'
    else:
        suffix = {1: 'st', 2: 'nd', 3: 'rd'}.get(n % 10, 'th')
    return f"{n}{suffix}"

def linkify(text):
    return sub(r'(https?://\S+?)([,.]?)(\s|$)', r'<a href="\1" target="_blank">🔗</a>\2\3', text)

def add_map_data(data_content, data_type='markers'):
    if not day_count in map_data.keys():
        map_data[day_count] = {'markers': [], 'routes': [], 'todos': [], 'dones': [], 'date_pretty': current_date_pretty}
    map_data[day_count][data_type].append(data_content)

def ensure_ul_open():
    """Emit <ul> opening tag if not already open."""
    global i_html, ul_open
    if not ul_open:
        i_html += '<ul>\n'
        ul_open = True

def close_ul_if_open():
    """Emit </ul> closing tag if currently open."""
    global i_html, ul_open
    if ul_open:
        i_html += '</ul>\n'
        ul_open = False

i_html = ''
ul_open = False
day_count = 0
current_date = False
current_date_pretty = False
last_date = False
first_date = False
first_date_pretty = False
last_date_pretty = False
map_data = {}
page_title = 'Tripsnip'
route_index = -1
route_stats = []
total_dist = 0.0
total_up = 0.0
total_down = 0.0
summary_placeholder = '\x00SUMMARY\x00'

if len(sys.argv) != 2:
    print("Usage: tripsnip <file.trps>", file=sys.stderr)
    sys.exit(1)

out_file = splitext(sys.argv[1])[0] + '.html'
sys.stdout = open(out_file, 'w', encoding='utf-8')

with open(sys.argv[1], 'r') as f:
    for l in f:
        l = l.strip()
        if not l: continue
        elif l.startswith('//'): continue
        elif l.startswith('todo:'):
            content = l.replace('todo:', '', 1).strip()
            ensure_ul_open()
            i_html += f'<li class="todo">{linkify(content)}</li>\n'
            add_map_data(content, data_type='todos')
        elif l.startswith('done:'):
            content = l.replace('done:', '', 1).strip()
            ensure_ul_open()
            i_html += f'<li class="done"><del>{linkify(content)}</del></li>\n'
            add_map_data(content, data_type='dones')
        elif l.startswith('marker:'):
            match = search(r'^marker:([0-9.-]+),([0-9.-]+)\s+(.*)', l)
            if match:
                lat, lng, txt = match.groups()
                ensure_ul_open()
                i_html += f'<li class="marker">{linkify(txt)} <a class="center-map-button" href="#" onclick="event.preventDefault();centerMapOnPoint({lat}, {lng});">🔍</a></li>\n'
                add_map_data({'lat': lat, 'lng': lng, 'txt': txt}, data_type='markers')
            else:
                raise ValueError(f"Malformed marker line: {l}")
        elif l.startswith('route:'):
            gpx_file = l.replace('route:', '', 1).strip()
            add_map_data(gpx_file, data_type='routes')
            route_index += 1
            with open(join(dirname(sys.argv[1]), gpx_file), 'r') as gf:
                gpx = gpxpy.parse(gf)
            dist = gpx.length_3d() / 1000
            up, down = gpx.get_uphill_downhill()
            total_dist += dist
            total_up += up
            total_down += down
            route_stats.append(f"{dist:.1f}km ↗{up:.0f}m ↘{down:.0f}m")
            b = gpx.get_bounds()
            l_bounds = [[b.min_latitude, b.min_longitude], [b.max_latitude, b.max_longitude]]
            ensure_ul_open()
            i_html += f'<li class="route">{dist:.1f}km ↗{up:.0f}m ↘{down:.0f}m <a class="center-map-button" href="#" onclick="event.preventDefault();centerMapByBounds({l_bounds})">🔍</a><a class="center-map-button" href="#" onclick="event.preventDefault();downloadtext({route_index}, \'{gpx_file}\')" title="{gpx_file}">⬇️</a></li>\n'
        elif l.startswith('## '):
            match = search(r'^##\ (\d{4})-(\d{2})-(\d{2})', l)
            close_ul_if_open()
            if match:
                y, m, d = map(int, match.groups())
                current_date = date(y, m, d)
                if not first_date:
                    first_date = current_date
                    day_count = 1
                else:
                    day_count = (current_date - first_date).days + 1
                last_date = current_date
                date_label = f"{current_date.strftime('%a')} {ordinal(current_date.day)} {current_date.strftime('%b %Y')}"
                current_date_pretty = f"{date_label}, Day {day_count}"
                if not first_date_pretty:
                    first_date_pretty = date_label
                last_date_pretty = date_label
                i_html += f'<h2>{current_date_pretty}</h2>\n'
            else:
                i_html += f'<h2>{l[3:]}</h2>\n'
        elif l.startswith('# '):
            page_title = l.lstrip('# ') + ' - Tripsnip'
            i_html += f'<h1>{l[2:]}</h1>\n'
            i_html += summary_placeholder + '\n'
        else:
            content = l.strip()
            ensure_ul_open()
            i_html += f'<li>{linkify(content)}</li>\n'

close_ul_if_open()

# Build summary and substitute placeholder
if first_date_pretty and last_date_pretty:
    num_days = (last_date - first_date).days + 1
    date_range_line = f'<li class="summary">{first_date_pretty} – {last_date_pretty}, {num_days} days</li>'
else:
    date_range_line = ''

if total_dist > 0:
    distance_line = f'<li class="summary">Distance {total_dist:.1f}km ↗{total_up:.0f}m ↘{total_down:.0f}m</li>'
else:
    distance_line = ''

all_lats = [float(m['lat']) for d in map_data.values() for m in d['markers']]
all_lngs = [float(m['lng']) for d in map_data.values() for m in d['markers']]
if all_lats:
    center_lat = round(sum(all_lats) / len(all_lats), 4)
    center_lng = round(sum(all_lngs) / len(all_lngs), 4)
    month_name = first_date.strftime('%B') if first_date else ''
    lat_str = f"{abs(center_lat)}{'S' if center_lat < 0 else 'N'}"
    lng_str = f"{abs(center_lng)}{'W' if center_lng < 0 else 'E'}"
    weather_url = f"https://www.meteoblue.com/en/weather/historyclimate/climatemodelled/{lat_str}-{lng_str}"
    weather_line = f'<li class="summary"><a href="{weather_url}" target="_blank">🌦️ Average climate</a></li>'
else:
    weather_line = ''

summary_html = '\n'.join(filter(None, [date_range_line, distance_line, weather_line]))
summary_block = f'<ul class="summary">\n{summary_html}\n</ul>\n' if summary_html else ''
i_html = i_html.replace(summary_placeholder + '\n', summary_block)

