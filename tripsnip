from xml.etree import ElementTree as ET

def build_combined_gpx():
    root = ET.Element('gpx', version='1.1', creator='tripsnip')
    for d in map_data.values():
        for m in d['markers']:
            wpt = ET.SubElement(root, 'wpt', lat=m['lat'], lon=m['lng'])
            ET.SubElement(wpt, 'name').text = m['txt']
        for r in d['routes']:
            with open(join(dirname(sys.argv[1]), r.strip()), 'r') as gf:
                gpx = gpxpy.parse(gf)
            trk = ET.SubElement(root, 'trk')
            ET.SubElement(trk, 'name').text = r.strip()
            for track in gpx.tracks:
                for segment in track.segments:
                    seg = ET.SubElement(trk, 'trkseg')
                    for pt in segment.points:
                        trkpt = ET.SubElement(seg, 'trkpt',
                            lat=str(pt.latitude), lon=str(pt.longitude))
                        if pt.elevation is not None:
                            ET.SubElement(trkpt, 'ele').text = str(pt.elevation)
    ET.indent(root, space='  ')
    return ET.tostring(root, encoding='unicode', xml_declaration=True)

def print_leaflet_gpx_routes_js():
    target_dir = dirname(sys.argv[1])
    if target_dir:
        chdir(target_dir)

    g_js = ''
    for d in map_data.values():
        for r in d['routes']:
            with open(r.strip(), 'r') as f:
                g_js += '`' + f.read() + '`,\n'
    print(g_js.rstrip(',\n'))

def print_leaflet_markers_js():
    m_js = ''
    for d in map_data.values():
        for m in d['markers']:
            clean_txt = m['txt'].replace("'", "\\'")
            clean_popup = linkify(m['txt']).replace("'", "\\'")
            m_js += "{ lat: " + m['lat'] + ", lng: " + m['lng'] + ", label: '" + clean_txt + "', popup: '" + clean_popup + "' },\n"
    print(m_js.rstrip(',\n'))

def print_elevation_profiles_js():
    target_dir = dirname(sys.argv[1])
    e_js = ''
    for d in map_data.values():
        for r in d['routes']:
            with open(join(target_dir, r.strip()), 'r') as gf:
                gpx = gpxpy.parse(gf)
            points = []
            dist = 0.0
            prev = None
            for track in gpx.tracks:
                for segment in track.segments:
                    for pt in segment.points:
                        if prev:
                            dist += pt.distance_3d(prev) / 1000
                        points.append([round(dist, 3), round(pt.elevation or 0, 1)])
                        prev = pt
            e_js += repr(points) + ',\n'
    print(e_js.rstrip(',\n'))

def ordinal(n):
    if 10 <= n % 100 <= 20:
        suffix = 'th'
    else:
        suffix = {1: 'st', 2: 'nd', 3: 'rd'}.get(n % 10, 'th')
    return f"{n}{suffix}"

def linkify(text):
    return sub(r'(https?://\S+?)([,.]?)(\s|$)', r'<a onclick="event.stopPropagation()" href="\1" target="_blank">🔗</a>\2\3', text)

def add_map_data(data_content, data_type='markers'):
    if not day_count in map_data.keys():
        map_data[day_count] = {'markers': [], 'routes': [], 'todos': [], 'dones': [], 'date_pretty': current_date_pretty}
    map_data[day_count][data_type].append(data_content)

def ensure_ul_open():
    global i_html, ul_open
    if not ul_open:
        i_html += '<ul>\n'
        ul_open = True

def close_ul_if_open():
    global i_html, ul_open
    if ul_open:
        i_html += '</ul>\n'
        ul_open = False

