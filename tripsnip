with open(sys.argv[1], 'r') as f:
    for l in f:
        l = l.strip()
        if not l: continue
        elif l.startswith('//'): continue
        elif l.startswith('todo:'):
            content = l.replace('todo:', '', 1).strip()
            ensure_ul_open()
            i_html += f'<li class="todo">{linkify(content)}</li>\n'
            add_map_data(content, data_type='todos')
        elif l.startswith('done:'):
            content = l.replace('done:', '', 1).strip()
            ensure_ul_open()
            i_html += f'<li class="done"><del>{linkify(content)}</del></li>\n'
            add_map_data(content, data_type='dones')
        elif l.startswith('marker:'):
            match = search(r'^marker:([0-9.-]+),([0-9.-]+)\s+(.*)', l)
            if match:
                lat, lng, txt = match.groups()
                ensure_ul_open()
                i_html += f'<li class="marker" style="cursor:pointer" onclick="centerMapOnPoint({lat}, {lng})">{linkify(txt)}</li>\n'
                add_map_data({'lat': lat, 'lng': lng, 'txt': txt}, data_type='markers')
            else:
                raise ValueError(f"Malformed marker line: {l}")
        elif l.startswith('route:'):
            gpx_file = l.replace('route:', '', 1).strip()
            add_map_data(gpx_file, data_type='routes')
            route_index += 1
            with open(join(dirname(sys.argv[1]), gpx_file), 'r') as gf:
                gpx = gpxpy.parse(gf)
            dist = gpx.length_3d() / 1000
            up, down = gpx.get_uphill_downhill()
            total_dist += dist
            total_up += up
            total_down += down
            route_stats.append(f"{dist:.1f}km ↑{up:.0f}m ↓{down:.0f}m")
            b = gpx.get_bounds()
            l_bounds = [[b.min_latitude, b.min_longitude], [b.max_latitude, b.max_longitude]]
            ensure_ul_open()
            i_html += f'<li class="route" style="cursor:pointer" onclick="selectRoute({route_index}, {l_bounds})">{dist:.1f}km ↑{up:.0f}m ↓{down:.0f}m <a href="#" onclick="event.stopPropagation();event.preventDefault();downloadtext({route_index}, \'{gpx_file}\')" title="{gpx_file}">⬇️</a></li>\n'
        elif l.startswith('## '):
            match = search(r'^##\ (\d{4})-(\d{2})-(\d{2})', l)
            close_ul_if_open()
            if match:
                y, m, d = map(int, match.groups())
                current_date = date(y, m, d)
                if not first_date:
                    first_date = current_date
                    day_count = 1
                else:
                    day_count = (current_date - first_date).days + 1
                last_date = current_date
                date_label = f"{current_date.strftime('%a')} {ordinal(current_date.day)} {current_date.strftime('%b %Y')}"
                current_date_pretty = f"{date_label}, Day {day_count}"
                if not first_date_pretty:
                    first_date_pretty = date_label
                last_date_pretty = date_label
                i_html += f'<h2>{current_date_pretty}</h2>\n'
            else:
                i_html += f'<h2>{l[3:]}</h2>\n'
        elif l.startswith('# '):
            page_title = l.lstrip('# ') + ' - Tripsnip'
            i_html += f'<h1>{l[2:]}</h1>\n'
            i_html += summary_placeholder + '\n'
        else:
            content = l.strip()
            ensure_ul_open()
            i_html += f'<li>{linkify(content)}</li>\n'

