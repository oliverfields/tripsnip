    const gpxColors = ['#00ffff','#ff00ff','#00ff00','#ff6600','#ff0099','#00ccff','#ffff00','#ff3300','#cc00ff','#00ff99'];
    const gpxData = [
''')
print_leaflet_gpx_routes_js()
print('];')

print('''
    let loaded = 0;
    gpxData.forEach((xml, i) => {
        const url = URL.createObjectURL(new Blob([xml], {type: 'application/gpx+xml'}));
        const color = gpxColors[i % gpxColors.length];
        new L.GPX(url, { async: true, marker_options: { startIconUrl: null, endIconUrl: null, shadowUrl: null }, polyline_options: { color: color, weight: 3 } })
        .on('loaded', e => {
            allBounds.extend(e.target.getBounds());
            map.fitBounds(allBounds, {padding: [30, 30]});
            loaded++;
            if(loaded === gpxData.length) {
                const c = map.getCenter(), z = map.getZoom();
                const h1 = document.querySelector('h1');
                if(h1) h1.onclick = () => map.setView(c, z);
            }
        }).addTo(map);
    });

    if(markers.length > 0 && gpxData.length === 0) map.fitBounds(allBounds);

    function toggleView() {
        const iti = document.getElementById('itinerary'), pane = document.getElementById('map-pane'), btn = document.getElementById('fab');
        if (pane.classList.contains('hidden')) {
            pane.classList.replace('hidden', 'visible');
            iti.classList.replace('visible', 'hidden');
            btn.innerText = '📄';
            setTimeout(() => { map.invalidateSize(); }, 50);
        } else {
            pane.classList.replace('visible', 'hidden');
            iti.classList.replace('hidden', 'visible');
            btn.innerText = '🗺️';
        }
    }

    function centerMapOnPoint(at, ng) { 
        if(window.innerWidth <= 768) toggleView();
        map.setView([at, ng], 14); 
    }
    function centerMapByBounds(b) { 
        if(window.innerWidth <= 768) toggleView();
        map.fitBounds(b); 
    }
    map.on('move', () => {
        const c = map.getCenter();
        document.getElementById('coords').innerText = `${c.lat.toFixed(6)},${c.lng.toFixed(6)}`;
    });
    document.getElementById('copy-btn').onclick = (e) => {
        e.stopPropagation();
        navigator.clipboard.writeText(document.getElementById('coords').innerText);
        document.getElementById('copy-btn').innerText = '✅';
        setTimeout(() => document.getElementById('copy-btn').innerText = '📋', 1000);
    };
    function downloadtext(i, n) {
        const a = document.createElement('a');
        a.href = URL.createObjectURL(new Blob([gpxData[i]], {type:'text/plain'}));
        a.download = n; a.click();
