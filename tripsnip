# -*- coding: utf-8 -*-

from sys import argv, exit
from re import search
from datetime import date
from markdown import markdown
from os.path import dirname, join
from os import chdir
import gpxpy

def print_leaflet_gpx_routes_js():
    target_dir = dirname(argv[1])
    if target_dir:
        chdir(target_dir)

    g_js = ''
    for d in map_data.values():
        for r in d['routes']:
            with open(r.strip(), 'r') as f:
                g_js += '`' + f.read() + '`,\n'
    print(g_js.rstrip(',\n'))

def print_leaflet_markers_js():
    m_js = ''
    for d in map_data.values():
        for m in d['markers']:
            clean_txt = m['txt'].replace("'", "\\'")
            m_js += "{ lat: " + m['lat'] + ", lng: " + m['lng'] + ", label: '" + clean_txt + "' },\n"
    print(m_js.rstrip(',\n'))

def ordinal(n):
    if 10 <= n % 100 <= 20:
        suffix = 'th'
    else:
        suffix = {1: 'st', 2: 'nd', 3: 'rd'}.get(n % 10, 'th')
    return f"{n}{suffix}"

def add_map_data(data_content, data_type='markers'):
    if not day_count in map_data.keys():
        map_data[day_count] = {'markers': [], 'routes': [], 'todos': [], 'dones': [], 'date_pretty': current_date_pretty}
    map_data[day_count][data_type].append(data_content)

i_md = '' 
day_count = 0
current_date = False
current_date_pretty = False
last_date = False
first_date = False
map_data = {}
page_title = 'Tripsnip'
route_index = -1

if len(argv) != 2:
    print("Usage: tripsnip <file.trps>")
    exit(1)

with open(argv[1], 'r') as f:
    for l in f:
        l = l.strip()
        if not l: continue

        if l.startswith('- todo:'):
            content = l.replace('- todo:', '', 1).strip()
            i_md += f'- {content}\n'
            add_map_data(content, data_type='todos')
        elif l.startswith('- done:'):
            content = l.replace('- done:', '', 1).strip()
            i_md += f'- <del>{content}</del>\n'
            add_map_data(content, data_type='dones')
        elif l.startswith('- marker:'):
            match = search(r'^- marker:([0-9.-]+),([0-9.-]+)\s+(.*)', l)
            if match:
                lat, lng, txt = match.groups()
                i_md += f'- <a href="#" onclick="event.preventDefault();centerMapOnPoint({lat}, {lng});">{txt}</a>\n'
                add_map_data({'lat': lat, 'lng': lng, 'txt': txt}, data_type='markers')
            else:
                print(f"Malformed marker line: {l}"); exit(1)
        elif l.startswith('- route:'):
            gpx_file = l.replace('- route:', '', 1).strip()
            add_map_data(gpx_file, data_type='routes')
            route_index += 1
            with open(join(dirname(argv[1]), gpx_file), 'r') as gf:
                gpx = gpxpy.parse(gf)
            dist = gpx.length_3d() / 1000
            up, down = gpx.get_uphill_downhill()
            b = gpx.get_bounds()
            l_bounds = [[b.min_latitude, b.min_longitude], [b.max_latitude, b.max_longitude]]
            i_md += f'- <a href="#" onclick="event.preventDefault();centerMapByBounds({l_bounds})">{gpx_file}</a> {dist:.1f}km ↗{up:.0f}m ↘{down:.0f}m <a href="#" onclick="event.preventDefault();downloadtext({route_index}, \'{gpx_file}\')">💾</a>\n'
        elif l.startswith('## '):
            match = search(r'^##\ (\d{4})-(\d{2})-(\d{2})', l)
            if match:
                y, m, d = map(int, match.groups())

                current_date = date(y, m, d)
                if not first_date:
                    first_date = current_date
                    day_count = 1
                else:
                    day_count = (current_date - first_date).days + 1
                last_date = current_date
                current_date_pretty = f"{current_date.strftime('%a')} {ordinal(current_date.day)} {current_date.strftime('%b %Y')}, Day {day_count}"

                i_md += f'## {current_date_pretty}\n'
            else: i_md += l + '\n'
        elif l.startswith('# '):
            page_title = l.lstrip('# ') + ' - Tripsnip'
            i_md += l + '\n'
        else: i_md += l + '\n'

